# ================================================
# A机构教育管理系统 - 环境变量配置
# 将此文件复制为 .env.local 并填写实际值
# ================================================

# JWT 密钥 (请修改为随机字符串)
JWT_SECRET=your_super_secret_jwt_key_change_this

# DeepSeek AI API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# DeepSeek 模型配置
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=deepseek-chat

# 通用 OpenAI 兼容配置（推荐：统一用这一组，便于切换到千问）
# DeepSeek 示例：
AI_API_KEY=your_api_key_here
AI_API_URL=https://api.deepseek.com/v1
AI_CHAT_MODEL=deepseek-chat
AI_VISION_MODEL=deepseek-chat
AI_EMBEDDING_MODEL=deepseek-chat
# 千问示例（之后切换时改这几项）：
# AI_API_KEY=your_qwen_key_here
# AI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_CHAT_MODEL=qwen-plus
# AI_VISION_MODEL=qwen-vl-plus
# AI_EMBEDDING_MODEL=text-embedding-v3

# 飞书 Webhook (在飞书群组创建自定义机器人后获取)
# 学生/班级异常通知 Webhook
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_id

# 数据库路径
DATABASE_PATH=./data/education.db

# 向量存储路径
VECTOR_STORE_PATH=./data/vector_store.json

# MediaPipe 姿态分析回调 Token
POSE_CALLBACK_TOKEN=your_pose_callback_token

# MediaPipe Worker 回调地址（本地开发通常为 http://localhost:3000）
API_BASE_URL=http://localhost:3000
